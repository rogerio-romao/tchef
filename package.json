{
    "name": "tchef",
    "version": "0.5.2",
    "description": "A better Fetch - with bells and whistles",
    "keywords": [
        "fetch",
        "http",
        "request",
        "response",
        "tchef"
    ],
    "homepage": "https://github.com/rogerio-romao/tchef#readme",
    "bugs": {
        "url": "https://github.com/rogerio-romao/tchef/issues"
    },
    "license": "MIT",
    "author": "Rogerio Romao",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/rogerio-romao/tchef.git"
    },
    "files": [
        "dist",
        "LICENSE",
        "README.md",
        "CHANGELOG.md"
    ],
    "type": "module",
    "sideEffects": false,
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        }
    },
    "scripts": {
        "build": "run-s build:node build:types",
        "build:node": "esbuild src/index.ts --bundle --platform=node --outfile=dist/index.js --format=esm --target=es2022 --minify --external:all",
        "build:types": "tsc -p tsconfig.build.json",
        "check": "run-s fmt:check lint typecheck test:ci build",
        "clean": "rm -rf dist",
        "dev": "run-p dev:*",
        "dev:esbuild": "pnpm run build --watch",
        "dev:node": "node --watch dist/index.js",
        "dev:tsc": "tsc --watch --preserveWatchOutput --noEmit",
        "fmt": "oxfmt",
        "fmt:check": "oxfmt --check",
        "lint": "oxlint",
        "lint:fix": "oxlint --fix",
        "prepublishOnly": "run-s clean build",
        "release": "np",
        "serve:db": "json-server ./src/server/db.json --port 3000",
        "start": "node dist/index.js",
        "test": "vitest",
        "test:ci": "CI=true vitest --run",
        "test:coverage": "CI=true vitest run --coverage",
        "test:local": "run-p serve:db test",
        "typecheck": "tsc --noEmit",
        "version": "changelogen && node -e \"const fs=require('fs');const pkg=JSON.parse(fs.readFileSync('package.json'));const jsr=JSON.parse(fs.readFileSync('jsr.json'));jsr.version=pkg.version;fs.writeFileSync('jsr.json',JSON.stringify(jsr,null,4)+'\\n');\" && git add CHANGELOG.md jsr.json"
    },
    "devDependencies": {
        "@types/node": "^25.5.0",
        "@vitest/coverage-v8": "^4.1.2",
        "@vitest/ui": "^4.1.2",
        "changelogen": "^0.6.2",
        "esbuild": "^0.25.0",
        "json-server": "1.0.0-beta.15",
        "np": "^10.2.0",
        "npm-run-all2": "^6.1.2",
        "oxfmt": "^0.42.0",
        "oxlint": "^1.57.0",
        "typescript": "^6.0.2",
        "valibot": "^1.3.1",
        "vite": "^6.0.0",
        "vitest": "^4.1.2"
    },
    "engines": {
        "node": ">=21.0.0"
    }
}
